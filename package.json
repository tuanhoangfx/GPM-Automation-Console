{
  "name": "gpm-automation-console",
  "version": "0.1.3",
  "private": true,
  "description": "Desktop console for managing and automating GPM Login profiles.",
  "author": "GPM Automation Console",
  "main": "electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/tuanhoangfx/GPM-Automation-Console.git"
  },
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc --noEmit && vite build",
    "audit:cleanup": "node scripts/audit-cleanup.mjs",
    "sync:changelog": "node scripts/sync-changelog.mjs",
    "sync:meta": "node scripts/sync-metadata-version.mjs",
    "sync:all": "pnpm sync:meta && pnpm sync:changelog",
    "pack": "corepack pnpm build && electron-builder --dir",
    "dist": "corepack pnpm build && electron-builder --win nsis-web --publish never",
    "release": "corepack pnpm build && electron-builder --win nsis-web --publish always",
    "preview": "vite preview --host 127.0.0.1",
    "start": "electron ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.561.0",
    "ms": "^2.1.3",
    "playwright-core": "^1.59.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^7.2.7",
    "wait-on": "^9.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.gpm.automation-console",
    "productName": "GPM Automation Console",
    "artifactName": "GPM-Automation-Console-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "win": {
      "target": "nsis-web"
    },
    "nsisWeb": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "tuanhoangfx",
        "repo": "GPM-Automation-Console",
        "releaseType": "release"
      }
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
